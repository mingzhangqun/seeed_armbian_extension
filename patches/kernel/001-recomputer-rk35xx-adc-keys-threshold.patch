From 5b9f37c0034ca639caac7d9d0675e04b34ac44fd Mon Sep 17 00:00:00 2001
From: mingzq <north_sea@qq.com>
Date: Sat, 16 May 2026 07:07:06 +0000
Subject: [PATCH] arm64: dts: rockchip: fix adc-keys press-threshold-microvolt
 for recomputer devkits

The volumeup-key press-threshold-microvolt was set to 1750 instead of
1750000 (1.75V), off by a factor of 1000. Fix for both rk3576 and rk3588
recomputer devkit boards.
---
 .../arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts | 2 +-
 .../arm64/boot/dts/rockchip/rk3588-recomputer-rk3588-devkit.dts | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts b/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts
index 28afce0731f7..2adaf2c59320 100644
--- a/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3576-recomputer-rk3576-devkit.dts
@@ -34,7 +34,7 @@ adc-keys {
 		volumeup-key {
 			linux,code = <KEY_VOLUMEUP>;
 			label = "volume up";
-			press-threshold-microvolt = <1750>;
+			press-threshold-microvolt = <1750000>;
 		};
 	};
 
diff --git a/arch/arm64/boot/dts/rockchip/rk3588-recomputer-rk3588-devkit.dts b/arch/arm64/boot/dts/rockchip/rk3588-recomputer-rk3588-devkit.dts
index 4862cc747216..568e8cd5fe59 100644
--- a/arch/arm64/boot/dts/rockchip/rk3588-recomputer-rk3588-devkit.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3588-recomputer-rk3588-devkit.dts
@@ -37,7 +37,7 @@ adc-keys {
 		volumeup-key {
 			linux,code = <KEY_VOLUMEUP>;
 			label = "volume up";
-			press-threshold-microvolt = <1750>;
+			press-threshold-microvolt = <1750000>;
 		};
 	};
 
-- 
2.53.0

