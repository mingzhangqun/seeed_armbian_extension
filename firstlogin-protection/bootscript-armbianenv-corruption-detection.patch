+setenv rootdev
 if load ${devtype} ${devnum}:${distro_bootpart} ${load_addr} ${prefix}armbianEnv.txt; then
-	if env import -t ${load_addr} ${filesize}; then
-		setenv armbian_env_loaded "yes"
