+# Atomic write helper: mv tmp to dest with sync
+atomic_write() {
+	local tmp="$1" dest="$2" mode="${3:-}"
+	[[ -n "$mode" ]] && chmod "$mode" "$tmp"
+	mv -f "$tmp" "$dest"
+	sync -f "$dest" 2>/dev/null || sync "$dest" 2>/dev/null
+}
