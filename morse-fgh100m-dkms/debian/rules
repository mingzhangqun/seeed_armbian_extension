#!/usr/bin/make -f

VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/-.*//')

%:
	dh $@ --parallel --with dkms

override_dh_install:
	dh_install dkms.conf Makefile usr/src/morse-fgh100m-$(VERSION)
	dh_install src/* usr/src/morse-fgh100m-$(VERSION)/src

override_dh_dkms:
	dh_dkms -V $(VERSION)

override_dh_fixperms:
	dh_fixperms
	find debian/morse-fgh100m-dkms/usr/src -type f -exec chmod -x {} \;

override_dh_builddeb:
	dh_builddeb -- -Zxz

# Nothing to configure, build or auto-install
override_dh_auto_configure:
override_dh_auto_build:
override_dh_auto_test:
override_dh_auto_install:
override_dh_auto_clean:
